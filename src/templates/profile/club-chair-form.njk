<div class="club-leadership-request">
  <ul>
  {% for club in clubs_with_user %}
    <li> {{club.name}}
    <button
        hx-delete="/profile/{{userId}}/club-chair/{{club.id}}"
        hx-confirm="Are you sure you want to remove yourself as a {{'(pending) ' if club.is_approved === 0 else ''}}chair of {{club.name}} ?"
        hx-target="closest section"
        hx-swap="innerHTML"
    ><img src="/static/icons/close-icon.svg"></button>
  {% endfor %}
  <ul>
</div>

<form hx-boost=true
      hx-push-url=false
      action=/profile/{{userId}}/club-chair
      method=post class="club-chair-request">
<div>
  <select name=club>
    {% for club in clubs_without_user %}
    <option value={{club.id}}>{{club.name}}</option>
    {% endfor %}
  </select>
  <button class="action approve" type=submit>Request</button>
</div>
<button class="action deny" hx-get="/profile/{{ userId }}?card=true">Close</button>
</form>
