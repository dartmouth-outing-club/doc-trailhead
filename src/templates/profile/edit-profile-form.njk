<section class="edit-profile">
<h3>Personal Info</h3>
{% if not noNameNorEmail %}
<label for="name">Name</label>
<input id="name" type=text name=name value="{{ name }}" required>
{% endif %}

<label for="pronouns">Pronouns</label>
<input id="pronouns" type=text name=pronouns value="{{ pronoun }}">

<label for="phone">
  Phone #
  <div class=hint>&nbsp;(just enter the number, no dashes)</div>
</label>
<input id="phone" type=text pattern="[0-9]{10,}" name="phone" value="{{ phone }}">

<label for="dash">DASH</label>
<input id="dash" type=text name="dash_number" value="{{ dash_number }}">

<label for="clothing-size">Clothing Size</label>
<select id="clothing-size" name="clothe_size" value="{{ clothe_size }}">
  <option {{ 'selected' if clothe_size == 'Women-XS' }}>Women-XS
  <option {{ 'selected' if clothe_size == 'Women-S' }}>Women-S
  <option {{ 'selected' if clothe_size == 'Women-M' }}>Women-M
  <option {{ 'selected' if clothe_size == 'Women-L' }}>Women-L
  <option {{ 'selected' if clothe_size == 'Women-XL' }}>Women-XL
  <option {{ 'selected' if clothe_size == 'Women-2XL' }}>Women-2XL
  <option {{ 'selected' if clothe_size == 'Women-3XL' }}>Women-3XL
  <option {{ 'selected' if clothe_size == 'Men-XS' }}>Men-XS
  <option {{ 'selected' if clothe_size == 'Men-S' }}>Men-S
  <option {{ 'selected' if clothe_size == 'Men-M' }}>Men-M
  <option {{ 'selected' if clothe_size == 'Men-L' }}>Men-L
  <option {{ 'selected' if clothe_size == 'Men-XL' }}>Men-XL
  <option {{ 'selected' if clothe_size == 'Men-2XL' }}>Men-2XL
  <option {{ 'selected' if clothe_size == 'Men-3XL' }}>Men-3XL
</select>

<label for="shoe-size">Shoe Size</label>
<div id="shoe-size">
  <select id="shoe-size-sex" name="shoe_size_sex">
    <option {{ 'selected' if shoe_size_sex == 'Men' }}>Men
    <option {{ 'selected' if shoe_size_sex == 'Women' }}>Women
  </select>
  <input id="shoe-size-num" type=number step=0.5 min=4 max=25 name="shoe_size_num" value="{{ shoe_size_num }}">
</div>


<label for="height">Height</label>
<div id="height" class="group">
  <input type=number name="feet" min=2 max=9 value="{{ feet }}">ft.
  <input type=number name="inches" min=0 max=11 value="{{ inches }}">in.
</div>

<label for="allergies-dietary">Allergies/Dietary Restrictions</label>
<input id="allergies-dietary" type=text name="allergies_dietary_restrictions" value="{{ allergies_dietary_restrictions }}">

<label for="medical-conditions">Medical Conditions</label>
<input id="medical-conditions" type=text name="medical_conditions" value="{{ medical_conditions }}">

<label for="medcert_type">Med Cert</label>
<select id="medcert_type" name="medcert_type" required>
  <option>(none)
  <option {{ 'selected' if medcert_type == "Basic First Aid(+CPR)"}}> Basic First Aid(+CPR)
  <option {{ 'selected' if medcert_type == "WFA"}}> WFA
  <option {{ 'selected' if medcert_type == "WAFA"}}> WAFA
  <option {{ 'selected' if medcert_type == "WFR"}}> WFR
  <option {{ 'selected' if medcert_type == "OEC"}}> OEC
  <option {{ 'selected' if medcert_type == "W-EMT"}}> W-EMT
</select>

<label for="medcert_expiration">Med Cert Expiration</label>
<input id="medcert_expiration" name="medcert_expiration" type="date" min="{{ today_iso }}" value={{ medcert_expiration_iso }}>

<script>
  document.getElementById('medcert_type').addEventListener('change', () => {
    const type = document.getElementById('medcert_type')
    const expiration = document.getElementById('medcert_expiration')
    expiration.setCustomValidity(type.value !== 'none' && !expiration.value ?
      `Please provide an expiration date for ${type.value} certification.` : '');
  })
  document.getElementById('medcert_expiration').addEventListener('change', (e) => {
    e.target.setCustomValidity('');
  })
</script>
</section>
